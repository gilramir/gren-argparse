module Main exposing (main)

{-| Demonstrates `Argparse.Program.runWithContext`: a command handler that needs a
`FileSystem.Permission`, acquired up front in the initialization phase and
threaded through as the program's *context*.

The `count` command reads a file and reports its size in bytes. It also shows
off the two ways `Argparse.Program` lets a handler signal failure:

  - a **missing** file fails the task, so its error message goes to stderr and
    the program exits `1`;
  - an **empty** file is treated as a failed check — the handler returns
    `Argparse.Program.Failed`, which exits `1` after printing its own note (no
    diagnostic from the runner).

A non-empty file exits `0` via `Argparse.Program.Succeeded`.

    ./run.sh count gren.json        # prints the size, exits 0
    ./run.sh count /no/such/file    # stderr error, exits 1
    ./run.sh count /dev/null        # "empty file", exits 1
    ./run.sh --help
-}

import Bytes
import Argparse.Parser
import Argparse.PrettyPrinter as PP
import Argparse.Program
import FileSystem
import FileSystem.Path as Path exposing (Path)
import Init
import Node
import Stream.Log
import Task


type Command
    = Count { path : Path }


type alias Context =
    { fs : FileSystem.Permission }


parser : Argparse.Parser.App Command
parser =
    { name = "filetool"
    , version = "1.0.0"
    , intro = PP.words "A tool that touches the filesystem."
    , outro = PP.empty
    , commands =
        Argparse.Parser.defineGroup
            |> Argparse.Parser.withCommand
                { word = "count"
                , arguments =
                    Argparse.Parser.oneArg
                        { value = Argparse.Parser.pathParser
                        , help = "The file to measure"
                        }
                , flags =
                    Argparse.Parser.noFlags
                , commonDescription =
                    Just "Report a file's size in bytes."
                , summary =
                    "The `count` command measures a file:"
                , example =
                    PP.words "filetool count gren.json"
                , builder =
                    \path _flags ->
                        Count { path = path }
                }
    }


main : Node.SimpleProgram a
main =
    Argparse.Program.runWithContext
        { parser = parser
        , init =
            \_env toProgram ->
                Init.await FileSystem.initialize <| \fsPermission ->
                    toProgram { fs = fsPermission }
        , onCommand =
            \env context command ->
                when command is
                    Count { path } ->
                        FileSystem.readFile context.fs path
                            -- A read error (e.g. no such file) fails the task,
                            -- so the runner prints this to stderr and exits 1.
                            |> Task.mapError FileSystem.errorToString
                            |> Task.andThen
                                (\contents ->
                                    if Bytes.length contents == 0 then
                                        -- Ran fine, but the answer is "no": a
                                        -- failed check. Print our own note and
                                        -- exit 1 with no extra diagnostic.
                                        Stream.Log.line env.stderr
                                            (Path.toPosixString path ++ " is empty")
                                            |> Task.map (\_ -> Argparse.Program.Failed)

                                    else
                                        Stream.Log.line env.stdout
                                            (Path.toPosixString path
                                                ++ ": "
                                                ++ String.fromInt (Bytes.length contents)
                                                ++ " bytes"
                                            )
                                            |> Task.map (\_ -> Argparse.Program.Succeeded)
                                )
        }
