module Main exposing (main)

{-| A CLI with **no sub-command** — just flags and an argument, like
`greet --loud World`. Built with `Argparse.Program.runRoot`, which parses a single
command without first consuming a command word.

    ./run.sh World            # Hello, World.
    ./run.sh --loud World     # HELLO, WORLD!
    ./run.sh --help
    ./run.sh --version
-}

import Argparse.Parser
import Argparse.PrettyPrinter as PP
import Argparse.Program
import Node
import Stream.Log
import Task


type Command
    = Greet { name : String, loud : Bool }


command : Argparse.Parser.Command String { loud : Bool } Command
command =
    { word = ""
    , arguments =
        Argparse.Parser.oneArg
            { value = nameParser
            , help = "Who to greet"
            }
    , flags =
        Argparse.Parser.initFlags (\loud -> { loud = loud })
            |> Argparse.Parser.toggle (Argparse.Parser.LongOnly "loud") "Shout the greeting"
    , commonDescription =
        Nothing
    , summary =
        "Greets someone by name:"
    , example =
        PP.words "greet --loud World"
    , builder =
        \name flags ->
            Greet { name = name, loud = flags.loud }
    }


main : Node.SimpleProgram a
main =
    Argparse.Program.runRoot
        { name = "greet"
        , version = "1.0.0"
        , command = command
        , onCommand =
            \env cmd ->
                when cmd is
                    Greet { name, loud } ->
                        Stream.Log.line env.stdout (greeting name loud)
                            |> Task.map (\_ -> {})
        }


greeting : String -> Bool -> String
greeting name loud =
    let
        base =
            "Hello, " ++ name
    in
    if loud then
        String.toUpper base ++ "!"

    else
        base ++ "."


nameParser : Argparse.Parser.ValueParser String
nameParser =
    { label = "name"
    , fn = Just
    , examples =
        [ "World"
        , "Alice"
        ]
    }
